# ============================================================
# FILE: .env.example
# PURPOSE: Required environment variables template
# SECURITY: Copy to .env — NEVER commit .env to version control
#           Add .env to .gitignore immediately
# ============================================================

# ── Server ──
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── MongoDB ──
# Use connection string with TLS in production
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb://localhost:27017/medical_inventory_dev

# ── JWT (Asymmetric RS256) ──
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Store raw PEM content (escape newlines as \n)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ISSUER=medical-inventory-api
JWT_AUDIENCE=medical-inventory-client
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Redis (Rate Limiting & Token Revocation) ──
REDIS_URL=redis://localhost:6379

# ── Google Cloud ──
# Set via Application Default Credentials — not a key file in code
# Run: gcloud auth application-default login
# Or set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_MAPS_API_KEY=your_server_side_maps_key_here
GCS_PRESCRIPTION_BUCKET=your-prescriptions-bucket-name
USE_GOOGLE_VISION=true

# ── Security ──
BCRYPT_ROUNDS=12


# NOTE: In production, inject all secrets via:
# - Cloud Secret Manager (GCP)
# - AWS Secrets Manager
# - HashiCorp Vault
# Never store production secrets in this file
